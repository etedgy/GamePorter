+	// Report device storage so scalar-access workarounds (atomics on vector components) cast correctly.
+	if (is_pointer(expression_type(ptr)) && expression_type(ptr).storage == StorageClassPhysicalStorageBuffer)
+		return StorageClassPhysicalStorageBuffer;
+
 	// If the expression has been lowered to a temporary, we need to use the Generic storage class.
 	// We're looking for the effective storage class of a given expression.
